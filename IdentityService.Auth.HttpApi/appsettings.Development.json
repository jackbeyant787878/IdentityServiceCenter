{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information",
      "OpenIddict": "Debug"
    }
  },
 

  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=sqlserverIP;Database=IdentityServiceDB;User Id=UserName;Password=Password;TrustServerCertificate=True;MultipleActiveResultSets=true;"
  },
  "Redis": {
    "Configuration": "redisIP,ssl=false,defaultDatabase=0"
  },
  "OpenIddictSettings": {
    "Issuer": "https://localhost:5001/",
    "AccessTokenLifetimeMinutes": 60,
    "RefreshTokenLifetimeDays": 14
  }
}